.profile-hero{display:flex;align-items:center;gap:17px;margin-top:20px;padding:20px}.profile-hero small{color:var(--muted);font-size:9px}.profile-hero h2{margin-top:4px;font-size:27px;color:var(--orange-900)}.profile-hero p{margin-top:2px;color:var(--orange-700);font-size:11px}.profile-setting-heading{display:flex;align-items:flex-start;justify-content:space-between;gap:14px}.profile-setting-heading h2{margin-top:5px;font-size:25px;color:var(--orange-900)}.profile-text-action{border:0;background:transparent;color:var(--orange-700);font-size:10px;font-weight:850}.photo-upload{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-top:16px;padding:14px;border:1px dashed rgba(244,119,33,.27);border-radius:17px;background:rgba(255,248,241,.72);cursor:pointer}.photo-upload strong,.photo-upload small{display:block}.photo-upload strong{color:var(--orange-900);font-size:11px}.photo-upload small{margin-top:3px;color:var(--muted);font-size:9px}.photo-upload>span:last-of-type{color:var(--orange-700);font-size:10px;font-weight:850}.photo-upload input{display:none}.fruit-picker{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:14px}.fruit-picker button{display:grid;gap:6px;place-items:center;min-height:94px;padding:9px 5px;border:1px solid var(--line);border-radius:19px;background:rgba(255,255,255,.72);transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease}.fruit-picker button:hover{transform:translateY(-2px);box-shadow:0 10px 24px rgba(78,45,26,.07)}.fruit-picker button.active{border-color:rgba(244,119,33,.55);background:var(--orange-100);box-shadow:0 10px 24px rgba(217,91,23,.08)}.fruit-picker small{color:var(--muted);font-size:8.5px}.fruit-avatar{position:relative;display:inline-grid;width:48px;height:48px;place-items:center;line-height:1}.fruit-avatar .fruit-glyph{font-size:38px;line-height:1;filter:drop-shadow(0 5px 7px rgba(74,42,24,.1))}.fruit-avatar .fruit-shades{position:absolute;left:50%;top:45%;transform:translate(-50%,-50%) rotate(-3deg);font-size:24px;line-height:1;filter:drop-shadow(0 2px 2px rgba(0,0,0,.18));pointer-events:none}.profile-avatar .fruit-avatar{width:64px;height:64px}.profile-avatar .fruit-glyph{font-size:53px}.profile-avatar .fruit-shades{font-size:32px}.profile-avatar.compact .fruit-avatar,.account-button .fruit-avatar{width:38px;height:38px}.profile-avatar.compact .fruit-glyph,.account-button .fruit-glyph{font-size:31px}.profile-avatar.compact .fruit-shades,.account-button .fruit-shades{font-size:19px}.story-avatar .fruit-avatar{width:36px;height:36px}.story-avatar .fruit-glyph{font-size:30px}.story-avatar .fruit-shades{font-size:18px}.profile-help{margin-top:8px;color:var(--muted);font-size:9.8px}.username-field{display:grid;grid-template-columns:auto 1fr;align-items:center;border:1.5px solid var(--line);border-radius:17px;background:rgba(255,255,255,.88);overflow:hidden}.username-field>span{padding-left:14px;color:var(--orange-700);font-weight:850}.username-field input{border:0!important;box-shadow:none!important;background:transparent!important}.profile-save{width:100%;margin-top:17px}.theme-picker{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-top:15px}.theme-picker button{display:flex;align-items:center;gap:11px;padding:12px;border:1px solid var(--line);border-radius:17px;background:rgba(255,255,255,.72);text-align:left}.theme-picker button.active{border-color:rgba(244,119,33,.43);background:var(--orange-100)}.theme-swatch{width:32px;height:32px;flex:0 0 32px;border-radius:11px}.theme-swatch.sunrise{background:linear-gradient(145deg,#ff7a24,#ffc18f)}.theme-swatch.dusk{background:linear-gradient(145deg,#60427e,#d6c1ed)}.theme-swatch.forest{background:linear-gradient(145deg,#315f4c,#a9d6b5)}.theme-swatch.midnight{background:linear-gradient(145deg,#244766,#a7c6dc)}.theme-picker strong,.theme-picker small{display:block}.theme-picker strong{color:var(--orange-900);font-size:10.5px}.theme-picker small{margin-top:2px;color:var(--muted);font-size:8.5px}.profile-account-actions,.privacy-actions{display:grid;gap:9px;margin-top:14px}

/* Tools */
.tool-stack{display:grid;gap:13px;margin-top:20px}.tool-card h2{font-size:27px;color:var(--orange-900)}.tool-card>p{margin-top:7px;color:var(--muted);font-size:11.5px}.breathe-area{text-align:center}.breathe-orb{display:grid;width:190px;height:190px;margin:24px auto 10px;place-items:center;border-radius:50%;background:radial-gradient(circle at 38% 30%,#fff,transparent 22%),linear-gradient(145deg,var(--orange-300),var(--orange-600) 58%,var(--lavender));color:#fff;box-shadow:0 20px 48px rgba(217,91,23,.22);transition:transform 4s ease,filter .4s ease}.breathe-orb.active{animation:breatheCycle 12s ease-in-out 1}.breathe-orb strong{font-size:18px}.breathe-time{margin-bottom:15px;color:var(--muted);font-size:10px}.ground-list{display:grid;gap:9px;margin-top:15px;list-style:none;counter-reset:ground}.ground-list li{counter-increment:ground;padding:12px 13px 12px 49px;position:relative;border:1px solid var(--line);border-radius:16px;background:rgba(255,255,255,.67);color:#56433a;font-size:11px}.ground-list li:before{content:counter(ground);position:absolute;left:10px;top:9px;display:grid;width:29px;height:29px;place-items:center;border-radius:10px;background:var(--orange-100);color:var(--orange-800);font-size:11px;font-weight:900}.affirmation{margin:17px 0;padding:19px;border-left:4px solid var(--green);border-radius:0 18px 18px 0;background:linear-gradient(90deg,var(--green-soft),rgba(255,255,255,.5));color:var(--orange-900);font-size:20px;font-weight:650;line-height:1.42}

/* Listen/read */
.playlist-tabs{display:flex;gap:8px;margin-top:20px;padding-bottom:4px;overflow-x:auto;scrollbar-width:none}.playlist-tabs::-webkit-scrollbar{display:none}.playlist-tabs button{flex:0 0 auto;min-height:42px;padding:9px 15px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.76);color:var(--muted);font-size:10.5px;font-weight:850}.playlist-tabs button.active{border-color:rgba(244,119,33,.38);background:var(--orange-800);color:#fff}.listen-now{display:grid;grid-template-columns:92px minmax(0,1fr);gap:16px;align-items:center}.sound-cover{display:grid;width:92px;height:92px;place-items:center;border-radius:22px;background:linear-gradient(145deg,var(--orange-300),var(--lavender));color:#fff;font-size:30px;box-shadow:0 12px 30px rgba(78,45,26,.13)}.listen-now h2{margin-top:5px;font-size:26px;color:var(--orange-900)}.listen-now p:last-child{margin-top:7px;color:var(--muted);font-size:11px}.ambient-viz{display:flex;align-items:flex-end;justify-content:center;gap:4px;height:60px;margin-top:18px;padding:12px;border-radius:16px;background:var(--orange-100)}.ambient-viz i{width:5px;height:12px;border-radius:99px;background:var(--orange-500)}.ambient-viz.playing i{animation:wave 1.1s ease-in-out infinite}.ambient-viz i:nth-child(2){animation-delay:-.2s}.ambient-viz i:nth-child(3){animation-delay:-.4s}.ambient-viz i:nth-child(4){animation-delay:-.6s}.ambient-viz i:nth-child(5){animation-delay:-.8s}.track-list{display:grid;gap:9px;margin-top:14px}.track-card{display:grid;grid-template-columns:38px minmax(0,1fr) 30px;gap:11px;align-items:center;width:100%;padding:13px 14px;border:1px solid var(--line);border-radius:19px;background:rgba(255,255,255,.76);text-align:left;color:var(--ink)}.track-card.active{border-color:rgba(244,119,33,.38);background:linear-gradient(145deg,var(--orange-100),#fff)}.track-number{display:grid;width:34px;height:34px;place-items:center;border-radius:12px;background:var(--orange-100);color:var(--orange-900);font-size:10px;font-weight:900}.track-card strong{display:block;color:var(--orange-900);font-size:12px}.track-card small{display:block;margin-top:3px;color:var(--muted);font-size:9.5px}.track-play{color:var(--orange-700);text-align:center}.reading-grid{display:grid;gap:12px;margin-top:20px}.reading-card{display:grid;grid-template-columns:48px minmax(0,1fr);gap:15px;align-items:start;width:100%;padding:19px;text-align:left;color:var(--ink)}.reading-mark{display:grid;width:44px;height:54px;place-items:center;border-radius:12px 12px 8px 8px;background:linear-gradient(160deg,var(--orange-900),var(--orange-600));color:#fff;font-size:15px;font-weight:800}.reading-card small{color:var(--orange-800);font-size:9px;font-weight:850;letter-spacing:.1em;text-transform:uppercase}.reading-card h2{margin-top:6px;font-size:24px;color:var(--orange-900)}.reading-card p{margin-top:7px;color:var(--muted);font-size:11px}.reader-panel{scroll-margin-top:90px}.reader-head{display:flex;align-items:flex-start;justify-content:space-between;gap:14px}.reader-head h2{margin-top:5px;font-size:26px;color:var(--orange-900)}.reader-close{min-height:40px;padding:8px 13px;border:1px solid var(--line);border-radius:999px;background:var(--orange-100);color:var(--orange-900);font-size:10px;font-weight:850}.reader-content{margin-top:15px}.reader-content h3{margin:22px 0 10px;font-size:24px;color:var(--orange-900)}.reader-content p{margin-bottom:13px;color:#46372f;font-size:13px;line-height:1.72}.reader-content blockquote{margin:18px 0;padding:16px 17px;border-left:4px solid var(--green);border-radius:0 15px 15px 0;background:linear-gradient(90deg,var(--green-soft),var(--orange-100));color:var(--orange-900);font-size:18px;font-weight:650;line-height:1.45}

/* Privacy/help */
.privacy-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-top:20px;overflow:hidden}.privacy-summary div{padding:18px;text-align:center;background:rgba(255,255,255,.6)}.privacy-summary span{display:block;color:var(--muted);font-size:9px}.privacy-summary strong{display:block;margin-top:6px;color:var(--orange-900);font-size:18px}.privacy-card h2{font-size:25px;color:var(--orange-900)}.privacy-card p{margin-top:7px;color:var(--muted);font-size:11px}.preference-field{display:grid;gap:7px;margin-top:15px}.preference-field span{color:var(--orange-900);font-size:10.5px;font-weight:850}.hotline-list{display:grid;gap:11px;margin-top:20px}.hotline{padding:20px;border:1px solid var(--line);border-radius:24px;background:rgba(255,255,255,.76);box-shadow:var(--soft-shadow)}.hotline.urgent{border-color:rgba(167,54,74,.22);background:linear-gradient(145deg,var(--danger-soft),#fff)}.hotline small{color:var(--orange-800);font-size:9px;font-weight:880;letter-spacing:.11em;text-transform:uppercase}.hotline.urgent small{color:var(--danger)}.hotline h2{margin-top:7px;font-size:31px;color:var(--orange-900)}.hotline p{margin-top:7px;color:var(--muted);font-size:11px}.disclaimer{margin-top:18px;color:var(--muted);font-size:10.5px;line-height:1.6}

/* Footer/tabbar */
.app-footer{padding:34px 16px 8px;text-align:center;color:var(--muted);font-size:9.5px}.app-footer strong{color:var(--orange-900)}
