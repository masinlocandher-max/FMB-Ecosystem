<!doctype html>
<html lang="en-PH">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="theme-color" content="#fff6ed">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Yoni">
<meta name="robots" content="index,follow">
<title>Yoni | Mental Health Companion</title>
<meta name="description" content="Yoni is a warm digital companion for honest check-ins, private journaling, grounding, kind community stories, and finding human support.">
<link rel="manifest" href="/app/manifest.webmanifest">
<link rel="icon" href="/app/yoni-icon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/app/yoni-icon.svg">
<style>
:root{
  --orange-900:#7b2e08;
  --orange-800:#a9430d;
  --orange-700:#d95b17;
  --orange-600:#f47721;
  --orange-500:#ff8d3f;
  --orange-300:#ffc18f;
  --orange-200:#ffdbc0;
  --orange-100:#fff0e3;
  --cream:#fffaf5;
  --paper:#ffffff;
  --ink:#33251e;
  --muted:#7a6a61;
  --green:#4d9d4a;
  --green-soft:#e9f5df;
  --lavender:#9c82d9;
  --lavender-soft:#efe8ff;
  --blue:#456f9a;
  --blue-soft:#eaf2fb;
  --danger:#a7364a;
  --danger-soft:#fff0f2;
  --line:rgba(87,56,38,.12);
  --glass:rgba(255,255,255,.76);
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bottom:env(safe-area-inset-bottom,0px);
  --tab-height:76px;
  --shadow:0 24px 70px rgba(92,52,25,.13);
  --soft-shadow:0 14px 38px rgba(92,52,25,.075);
}
*{box-sizing:border-box;margin:0;padding:0}
html{min-height:100%;scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{min-height:100dvh;overflow-x:hidden;color:var(--ink);background:
  radial-gradient(circle at 8% 0,rgba(255,171,111,.38),transparent 30%),
  radial-gradient(circle at 100% 12%,rgba(158,132,221,.26),transparent 31%),
  linear-gradient(180deg,#fff8f2 0%,#fffdfb 53%,#f7f1ff 100%);
  font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text","Avenir Next","Segoe UI",sans-serif;
  line-height:1.55;-webkit-font-smoothing:antialiased}
body[data-theme="dusk"]{--orange-900:#44305f;--orange-800:#60427e;--orange-700:#7b5aa3;--orange-600:#9373bd;--orange-500:#ae8bd3;--orange-300:#d7c5ed;--orange-200:#e9dff6;--orange-100:#f6f0fb;--green:#6a9d72;--green-soft:#e8f3e7;background:radial-gradient(circle at 7% 0,rgba(209,179,235,.45),transparent 31%),radial-gradient(circle at 100% 14%,rgba(244,170,132,.24),transparent 31%),linear-gradient(180deg,#fdf8ff 0%,#fffdfa 55%,#f0e8f8 100%)}
body[data-theme="forest"]{--orange-900:#24483a;--orange-800:#315f4c;--orange-700:#3f7b60;--orange-600:#559873;--orange-500:#72b58a;--orange-300:#b9dcc4;--orange-200:#d8eadc;--orange-100:#edf7ef;--green:#e77e2e;--green-soft:#fff0e4;background:radial-gradient(circle at 8% 0,rgba(166,211,174,.38),transparent 31%),radial-gradient(circle at 100% 14%,rgba(255,173,113,.22),transparent 31%),linear-gradient(180deg,#f7fff8 0%,#fffdf9 53%,#eaf4ec 100%)}
body[data-theme="midnight"]{--orange-900:#17324e;--orange-800:#244766;--orange-700:#345f83;--orange-600:#49789f;--orange-500:#6594b7;--orange-300:#bed5e5;--orange-200:#d9e7f0;--orange-100:#edf4f8;--green:#d77a31;--green-soft:#fff0e4;background:radial-gradient(circle at 8% 0,rgba(137,180,211,.35),transparent 31%),radial-gradient(circle at 100% 14%,rgba(255,166,105,.18),transparent 31%),linear-gradient(180deg,#f6fbff 0%,#fffdf9 53%,#e8f0f7 100%)}
button,input,textarea,select{font:inherit}
button{cursor:pointer}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
[hidden]{display:none!important}
:focus-visible{outline:3px solid rgba(244,119,33,.32);outline-offset:3px}

/* Yoni strip */
.preview-strip{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:center;gap:10px;min-height:32px;padding:6px 14px;background:#2f241e;color:#fff7ef;font-size:10px;font-weight:760;letter-spacing:.06em;text-transform:uppercase}
.preview-strip button{border:0;border-bottom:1px solid rgba(255,255,255,.5);background:transparent;color:#fff;font-size:10px;font-weight:800}

/* Access gate */
.access-gate{min-height:100dvh;padding:calc(var(--safe-top) + 56px) 18px 44px;display:grid;place-items:center}
.access-stage{width:min(1120px,100%);position:relative}
.access-brandbar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:20px}
.access-brand{display:flex;align-items:center;gap:12px}
.access-brand img{width:54px;height:54px;border-radius:18px;box-shadow:0 12px 28px rgba(94,48,22,.16)}
.access-brand span{display:grid;line-height:1.05}.access-brand strong{font-size:22px;letter-spacing:-.045em}.access-brand small{margin-top:5px;color:var(--muted);font-size:10px;font-weight:760;letter-spacing:.08em;text-transform:uppercase}
.access-site-link{padding:10px 14px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.68);color:var(--muted);font-size:11px;font-weight:780}
.access-layout{display:grid;grid-template-columns:minmax(0,1.08fr) minmax(360px,.72fr);gap:25px;align-items:stretch}
.access-intro,.access-card{border:1px solid rgba(255,255,255,.88);border-radius:38px;background:rgba(255,255,255,.73);box-shadow:var(--shadow);backdrop-filter:blur(24px) saturate(145%);-webkit-backdrop-filter:blur(24px) saturate(145%)}
.access-intro{position:relative;min-height:670px;padding:42px;overflow:hidden;background:
 radial-gradient(circle at 76% 20%,rgba(255,255,255,.9),transparent 18%),
 linear-gradient(145deg,rgba(255,245,235,.94),rgba(255,204,165,.9) 48%,rgba(213,196,247,.9))}
.access-intro:before,.access-intro:after{content:"";position:absolute;border:1px solid rgba(255,255,255,.5);border-radius:50%}.access-intro:before{width:420px;height:420px;right:-180px;top:-110px}.access-intro:after{width:280px;height:280px;left:-120px;bottom:-110px}
.access-copy{position:relative;z-index:2;max-width:590px}
.access-kicker,.kicker{color:var(--orange-800);font-size:10px;font-weight:880;letter-spacing:.15em;text-transform:uppercase}
.access-intro h1{max-width:680px;margin-top:15px;font-size:clamp(48px,7vw,84px);font-weight:760;line-height:.92;letter-spacing:-.072em}
.access-intro h1 em{font-style:normal;color:var(--orange-700)}
.access-lede{max-width:560px;margin-top:20px;color:#65554c;font-size:16px;line-height:1.7}
.access-benefits{display:grid;gap:10px;margin-top:28px;max-width:540px}.access-benefits span{display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid rgba(92,52,25,.09);border-radius:16px;background:rgba(255,255,255,.54);font-size:12px;font-weight:700}.access-benefits svg{width:21px;height:21px;fill:none;stroke:var(--orange-700);stroke-width:1.8}
.access-mascot{position:absolute;z-index:1;width:min(430px,52%);right:8px;bottom:-10px;filter:drop-shadow(0 24px 28px rgba(96,49,22,.18))}
.access-float{position:absolute;z-index:1;display:grid;width:55px;height:55px;place-items:center;border:1px solid rgba(255,255,255,.72);border-radius:19px;background:rgba(255,255,255,.58);box-shadow:0 13px 28px rgba(80,44,22,.1);font-size:22px;backdrop-filter:blur(12px);animation:floaty 5s ease-in-out infinite}.access-float.one{right:39%;bottom:25%;transform:rotate(-8deg)}.access-float.two{right:9%;top:19%;animation-delay:-2s}
.access-card{padding:25px;align-self:stretch}
.access-card-head{margin-bottom:18px}.access-card-head h2{font-size:29px;letter-spacing:-.045em}.access-card-head p{margin-top:7px;color:var(--muted);font-size:12px}
.access-segment{display:grid;grid-template-columns:1fr 1fr;gap:5px;padding:5px;border-radius:17px;background:var(--orange-100)}.access-segment button{min-height:43px;border:0;border-radius:13px;background:transparent;color:var(--muted);font-size:11px;font-weight:820}.access-segment button.active{background:#fff;color:var(--orange-900);box-shadow:0 5px 16px rgba(73,43,25,.08)}
.access-panel{padding-top:18px}.access-panel-heading h3{font-size:24px;letter-spacing:-.035em}.access-panel-heading p{margin-top:6px;color:var(--muted);font-size:11.5px}
.access-form{display:grid;gap:13px;margin-top:18px}.access-field{display:grid;gap:7px}.access-field>span{color:var(--orange-900);font-size:10.5px;font-weight:820}.access-field input{width:100%;min-height:51px;padding:13px 14px;border:1.5px solid var(--line);border-radius:16px;background:rgba(255,255,255,.86);color:var(--ink);outline:none}.access-field input:focus{border-color:rgba(244,119,33,.48);box-shadow:0 0 0 4px rgba(244,119,33,.1)}
.access-consent{display:grid;grid-template-columns:18px 1fr;gap:9px;align-items:start;color:var(--muted);font-size:10.5px}.access-consent input{margin-top:2px}.access-consent a{text-decoration:underline}
.access-primary,.access-secondary{display:inline-flex;min-height:50px;align-items:center;justify-content:center;padding:12px 17px;border-radius:16px;font-size:11.5px;font-weight:850}.access-primary{border:0;background:linear-gradient(135deg,var(--orange-700),var(--orange-500));color:#fff;box-shadow:0 12px 26px rgba(217,91,23,.22)}.access-secondary{border:1px solid var(--line);background:#fff;color:var(--orange-900)}
.access-preview{width:100%;margin-top:11px;border:0;background:transparent;color:var(--orange-800);font-size:11px;font-weight:800;text-decoration:underline;text-underline-offset:4px}
.access-security{display:flex;gap:8px;margin-top:17px;padding-top:15px;border-top:1px solid var(--line);color:var(--muted);font-size:9.8px;line-height:1.5}.access-security svg{width:18px;height:18px;flex:0 0 18px;fill:none;stroke:var(--green);stroke-width:1.8}
.access-status{display:none;padding:11px 12px;border-radius:13px;background:var(--green-soft);color:#356d35;font-size:10.5px}.access-status.visible{display:block}

/* App shell */
.app-shell{width:min(820px,100%);min-height:100dvh;margin:0 auto;padding-top:42px;padding-bottom:calc(var(--tab-height) + var(--safe-bottom) + 28px);position:relative}
.app-header{position:sticky;top:32px;z-index:40;display:flex;align-items:center;justify-content:space-between;gap:14px;padding:calc(var(--safe-top) + 10px) 16px 12px;background:linear-gradient(180deg,rgba(255,250,245,.96) 72%,rgba(255,250,245,0));backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px)}
.brand{display:flex;align-items:center;gap:10px;min-width:0}.brand img{width:42px;height:42px;border-radius:14px;box-shadow:0 8px 22px rgba(90,48,23,.12)}.brand-copy{display:grid;line-height:1.05}.brand-copy strong{font-size:19px;font-weight:820;letter-spacing:-.045em;color:var(--orange-900)}.brand-copy span{margin-top:4px;color:var(--muted);font-size:9px;font-weight:800;letter-spacing:.11em;text-transform:uppercase}
.app-header-actions{display:flex;align-items:center;gap:8px}.help-button,.account-button{display:grid;min-height:42px;place-items:center;border:1px solid var(--line);background:rgba(255,255,255,.84);box-shadow:0 8px 20px rgba(77,46,28,.06)}.help-button{padding:9px 14px;border-radius:999px;color:var(--danger);font-size:10.5px;font-weight:850}.account-button{width:42px;height:42px;border-radius:15px;color:var(--orange-900);font-size:12px;font-weight:900;background:linear-gradient(145deg,#fff,var(--orange-100))}
