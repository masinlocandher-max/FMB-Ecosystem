.chat-shell{margin-top:20px;overflow:hidden}.chat-head{display:flex;align-items:center;gap:12px;padding:16px 17px;border-bottom:1px solid var(--line);background:linear-gradient(145deg,rgba(255,255,255,.9),rgba(255,240,227,.76))}.chat-head img{width:52px;height:52px;object-fit:contain}.chat-head div{flex:1}.chat-head strong{display:block;color:var(--orange-900);font-size:14px}.chat-head span{display:flex;align-items:center;gap:6px;margin-top:2px;color:var(--muted);font-size:10px}.online-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 0 4px rgba(77,157,74,.14)}.chat-head small{padding:7px 9px;border-radius:999px;background:var(--green-soft);color:#3d743b;font-size:8.5px;font-weight:850;text-transform:uppercase}.chat-log{min-height:430px;max-height:56vh;padding:18px;overflow-y:auto;background:linear-gradient(180deg,rgba(255,255,255,.68),rgba(255,248,241,.72))}.bubble-row{display:flex;gap:8px;margin-bottom:12px;animation:bubbleIn .3s ease}.bubble-row.user{justify-content:flex-end}.bubble-avatar{width:30px;height:30px;flex:0 0 30px;align-self:flex-end;object-fit:contain}.bubble{max-width:min(76%,520px);padding:11px 13px;border-radius:18px 18px 18px 6px;background:#fff;color:var(--ink);box-shadow:0 7px 18px rgba(75,45,27,.06);font-size:12px;line-height:1.55}.user .bubble{border-radius:18px 18px 6px 18px;background:linear-gradient(135deg,var(--orange-700),var(--orange-500));color:#fff}.bubble small{display:block;margin-top:6px;color:var(--muted);font-size:8.5px}.user .bubble small{color:rgba(255,255,255,.72)}.typing{display:flex;gap:4px;align-items:center}.typing i{width:6px;height:6px;border-radius:50%;background:var(--orange-400,var(--orange-500));animation:typing 1.2s infinite}.typing i:nth-child(2){animation-delay:.15s}.typing i:nth-child(3){animation-delay:.3s}.chat-chips{display:flex;gap:7px;padding:0 16px 13px;overflow-x:auto;background:rgba(255,248,241,.72);scrollbar-width:none}.chat-chips::-webkit-scrollbar{display:none}.chat-chip{flex:0 0 auto;min-height:37px;padding:8px 12px;border:1px solid var(--line);border-radius:999px;background:#fff;color:var(--orange-900);font-size:10px;font-weight:780}.chat-compose{display:grid;grid-template-columns:1fr 48px;gap:8px;padding:13px;border-top:1px solid var(--line);background:rgba(255,255,255,.9)}.chat-compose textarea{min-height:48px;max-height:120px;padding:13px 14px;border:1.5px solid var(--line);border-radius:16px;resize:none;outline:none;font-size:13px}.chat-compose textarea:focus{border-color:rgba(244,119,33,.48);box-shadow:0 0 0 4px rgba(244,119,33,.09)}.chat-send{display:grid;width:48px;height:48px;place-items:center;border:0;border-radius:16px;background:linear-gradient(135deg,var(--orange-700),var(--orange-500));color:#fff;font-size:18px;box-shadow:0 10px 22px rgba(217,91,23,.2)}.chat-note{padding:0 16px 14px;background:rgba(255,255,255,.9);color:var(--muted);font-size:9px}

/* Check-in */
.mood-list{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:12px;margin-top:22px}.mood-option{position:relative;display:grid;aspect-ratio:1;place-items:center;width:100%;padding:8px;border:1px solid var(--line);border-radius:24px;background:rgba(255,255,255,.8);color:var(--ink);transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease,background .18s ease}.mood-option:hover{transform:translateY(-3px);border-color:rgba(244,119,33,.26);box-shadow:0 12px 26px rgba(217,91,23,.08)}.mood-option.selected{transform:translateY(-3px) scale(1.03);border-color:rgba(244,119,33,.62);background:linear-gradient(145deg,#fff,var(--orange-100));box-shadow:0 14px 30px rgba(217,91,23,.14)}.mood-option.selected:after{content:"✓";position:absolute;right:7px;bottom:7px;display:grid;width:20px;height:20px;place-items:center;border-radius:50%;background:var(--orange-700);color:#fff;font-size:10px;font-weight:900}.mood-emoji{display:block;font-size:clamp(34px,7vw,52px);line-height:1;filter:drop-shadow(0 6px 9px rgba(80,45,25,.08));transition:transform .18s ease}.mood-option:hover .mood-emoji,.mood-option.selected .mood-emoji{transform:scale(1.08)}.feeling-ack{margin-top:16px;padding:20px;background:linear-gradient(145deg,rgba(255,255,255,.9),rgba(255,240,227,.86))}.ack-head{display:flex;align-items:center;gap:12px}.ack-head>span{font-size:34px}.feeling-ack h2{margin-top:3px;font-size:24px;color:var(--orange-900)}.feeling-ack>p{margin-top:10px;color:var(--muted);font-size:12px}.field{display:grid;gap:7px;margin-top:18px}.field label,.field>span{color:var(--orange-900);font-size:10.5px;font-weight:850}.field textarea,.field input,.preference-field select{width:100%;min-height:50px;padding:14px 15px;border:1.5px solid var(--line);border-radius:17px;background:rgba(255,255,255,.88);color:var(--ink);font-size:15px;outline:none}.field textarea{min-height:130px;resize:vertical;line-height:1.55}.field textarea:focus,.field input:focus,.preference-field select:focus{border-color:rgba(244,119,33,.48);box-shadow:0 0 0 4px rgba(244,119,33,.1)}.support-inline{display:none;margin-top:16px;padding:20px;border-color:rgba(167,54,74,.17);background:linear-gradient(145deg,#fff5f7,#fff)}.support-inline.visible{display:block}.support-inline h3{font-size:23px;color:var(--danger)}.support-inline p{margin:8px 0 15px;color:var(--muted);font-size:11.5px}.gentle-options{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}.gentle-option{min-height:42px;padding:9px 13px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.76);color:var(--orange-900);font-size:10px;font-weight:800}.form-actions{display:grid;gap:9px;margin-top:18px}.confirmation{display:none;margin-top:18px;padding:20px;text-align:center}.confirmation.visible{display:block}.confirmation h3{font-size:27px;color:var(--orange-900)}.confirmation p{margin-top:8px;color:var(--muted);font-size:11.5px}

/* Journal, history */
.journal-form{margin-top:20px;padding:20px}.journal-meta{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:12px;color:var(--muted);font-size:10px}.journal-list{display:grid;gap:11px;margin-top:15px}.journal-entry{padding:18px}.journal-entry time{display:block;color:var(--orange-800);font-size:9px;font-weight:850;letter-spacing:.1em;text-transform:uppercase}.journal-entry p{margin-top:9px;color:var(--ink);font-size:12.5px;white-space:pre-wrap}.entry-bottom{display:flex;justify-content:flex-end;margin-top:12px;padding-top:10px;border-top:1px solid var(--line)}.entry-bottom button{border:0;background:transparent;color:var(--danger);font-size:10px;font-weight:800}.empty{padding:22px;text-align:center;color:var(--muted);font-size:11.5px}.calendar-card{margin-top:20px;padding:18px}.calendar-head{display:flex;align-items:center;justify-content:space-between;gap:12px}.calendar-head h2{font-size:26px;text-align:center;color:var(--orange-900)}.calendar-nav{display:grid;width:42px;height:42px;place-items:center;border:1px solid var(--line);border-radius:14px;background:#fff;color:var(--orange-900);font-size:20px}.calendar-weekdays,.calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}.calendar-weekdays{margin-top:18px}.calendar-weekdays span{text-align:center;color:var(--muted);font-size:8.5px;font-weight:850;text-transform:uppercase}.calendar-grid{margin-top:7px}.calendar-day{position:relative;display:grid;min-height:58px;align-content:start;justify-items:center;gap:2px;padding:7px 2px;border:1px solid transparent;border-radius:15px;background:rgba(255,255,255,.56);color:var(--ink)}.calendar-day.outside{opacity:.26}.calendar-day.has-data{border-color:rgba(244,119,33,.18);background:#fff}.calendar-day.selected{border-color:rgba(244,119,33,.52);background:var(--orange-100);box-shadow:0 8px 20px rgba(217,91,23,.08)}.calendar-day.today .day-number{background:var(--orange-800);color:#fff}.day-number{display:grid;width:25px;height:25px;place-items:center;border-radius:50%;font-size:10px;font-weight:850}.day-emoji{min-height:18px;font-size:15px}.day-journal{width:5px;height:5px;border-radius:50%;background:var(--green)}.calendar-legend{display:flex;gap:14px;margin-top:14px;color:var(--muted);font-size:9.5px}.calendar-legend span{display:flex;align-items:center;gap:5px}.legend-dot{width:6px;height:6px;border-radius:50%;background:var(--green)}.history-detail{margin-top:14px;padding:20px}.history-detail h3{font-size:24px;color:var(--orange-900)}.history-detail p{margin-top:8px;color:var(--muted);font-size:11.5px}.history-record{margin-top:12px;padding:13px;border:1px solid var(--line);border-radius:16px;background:rgba(255,255,255,.66)}.history-record strong{display:block;color:var(--orange-900);font-size:11px}.history-record span{display:block;margin-top:4px;color:var(--muted);font-size:10px}.history-actions{margin-top:14px}

/* Community */
.community-compose,.profile-settings,.privacy-card,.tool-card,.listen-player,.reader-panel{margin-top:18px;padding:20px}.community-identity{display:flex;align-items:center;gap:11px;margin-bottom:4px}.profile-avatar{display:grid;width:76px;height:76px;place-items:center;border:1px solid var(--line);border-radius:24px;background:linear-gradient(145deg,#fff,var(--orange-100));color:var(--orange-900);font-size:22px;font-weight:900;background-size:cover;background-position:center}.profile-avatar.compact{width:44px;height:44px;border-radius:15px;font-size:14px}.community-identity div{flex:1}.community-identity small{display:block;color:var(--muted);font-size:9px}.community-identity strong{display:block;color:var(--orange-900);font-size:12px}.moderation-pill{padding:6px 8px;border-radius:999px;background:var(--green-soft);color:#3c713a;font-size:8.5px;font-weight:850}.community-consent{display:grid;grid-template-columns:17px 1fr;gap:9px;margin-top:14px;color:var(--muted);font-size:10px}.community-compose-meta{display:flex;justify-content:space-between;gap:12px;margin-top:8px;color:var(--muted);font-size:9.5px}.community-submit{width:100%;margin-top:15px}.community-feed,.community-queue{display:grid;gap:11px}.story-card{padding:18px}.story-head{display:flex;align-items:center;gap:10px}.story-avatar{display:grid;width:40px;height:40px;place-items:center;border-radius:14px;background:var(--orange-100);font-size:19px}.story-head div{flex:1}.story-head strong{display:block;color:var(--orange-900);font-size:11.5px}.story-head span{display:block;color:var(--muted);font-size:9px}.story-card p{margin-top:13px;color:#4b3930;font-size:12px;line-height:1.62}.story-tag{display:inline-flex;margin-top:13px;padding:6px 9px;border-radius:999px;background:var(--green-soft);color:#3d713c;font-size:8.5px;font-weight:850}.queue-card{padding:15px;border:1px dashed rgba(244,119,33,.28);border-radius:18px;background:rgba(255,248,241,.7)}.queue-card strong{display:block;color:var(--orange-900);font-size:11px}.queue-card p{margin-top:5px;color:var(--muted);font-size:10.5px}.inline-status{display:none;margin-top:11px;padding:11px 12px;border-radius:13px;background:var(--green-soft);color:#356d35;font-size:10.5px}.inline-status.visible{display:block}

/* Profile */
