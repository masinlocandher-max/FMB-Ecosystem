<script>
window.YONI_ASSETS={"mascot":"/app/yoni-mascot.svg","motion":"/app/yoni-mascot.svg","portrait":"/assets/images/founder.webp","senz":"/app/senz-wordmark.svg","cognita":"/app/cognita-wordmark.svg"};
</script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/js/config.js"></script>
<script src="/assets/js/supabase-client.js"></script>
<script>
(()=>{
'use strict';
const $=s=>document.querySelector(s), $$=s=>[...document.querySelectorAll(s)];
const assetSrc=name=>window.YONI_ASSETS?.[name]||'/app/yoni-icon.svg';
function hydrateAssets(root=document){root.querySelectorAll?.('[data-yoni-asset]').forEach(image=>{const source=assetSrc(image.dataset.yoniAsset);if(source)image.src=source})}
hydrateAssets();
const keys={checkins:'yoni-checkins-v4',journals:'yoni-journals-v4',chat:'yoni-chat-v4',profile:'yoni-profile-v4',queue:'yoni-wall-queue-v4',theme:'yoni-theme-v4',reminder:'yoni-reminder-v4',unknown:'yoni-unknown-questions-v1',responseMode:'yoni-response-mode-v1'};
const read=(k,fallback=[])=>{try{return JSON.parse(localStorage.getItem(k))??fallback}catch{return fallback}};
const write=(k,v)=>{try{localStorage.setItem(k,JSON.stringify(v));return true}catch{return false}};
const escapeHtml=v=>String(v).replace(/[&<>'"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
const dateKey=(d=new Date())=>`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
const formatDate=d=>new Intl.DateTimeFormat('en-PH',{weekday:'short',month:'short',day:'numeric',year:'numeric'}).format(d);
const fruit={orange:'🍊',apple:'🍎',grapes:'🍇',cherry:'🍒',peach:'🍑',lemon:'🍋',blueberry:'🫐',watermelon:'🍉'};
const fruitAvatarHtml=key=>{const safe=fruit[key]?key:'orange';return `<span class="fruit-avatar" aria-hidden="true"><span class="fruit-glyph">${fruit[safe]}</span><span class="fruit-shades">🕶️</span></span>`};
let profile=read(keys.profile,{name:'Friend',username:'friend',fruit:'orange',bio:''});
if(!fruit[profile.fruit])profile.fruit='orange';
let selectedMood=null, selectedMoodButton=null, calendarCursor=new Date(new Date().getFullYear(),new Date().getMonth(),1), selectedHistory=dateKey();
let audioCtx=null, audioNodes=[], activeSound='rain', soundPlaying=false;
let authClient=null,authUser=null,accountProfile=null;
const YONI_URL='https://yoni.francinemariebautista.com/';
const themeFromDb=value=>({violet:'dusk',navy:'midnight',forest:'forest',slate:'sunrise',sunrise:'sunrise',dusk:'dusk',midnight:'midnight'})[value]||'sunrise';
const themeToDb=value=>({sunrise:'slate',dusk:'violet',forest:'forest',midnight:'navy'})[value]||'slate';
const memberName=(user,db)=>db?.full_name||db?.display_name||user?.user_metadata?.full_name||user?.email?.split('@')[0]?.replace(/[._-]+/g,' ')||'Friend';
const memberProfileToLocal=(user,db)=>{
  const existing=read(keys.profile,{});
  return {
    ...existing,
    name:memberName(user,db),
    username:db?.username||existing.username||window.FMB?.usernameFrom?.(user?.email?.split('@')[0])||'friend',
    fruit:fruit[db?.avatar_preset]?db.avatar_preset:(fruit[existing.fruit]?existing.fruit:'orange'),
    bio:db?.bio||existing.bio||''
  };
};
async function loadMemberProfile(user){
  if(!authClient||!user)return null;
  try{
    const {data,error}=await authClient.from('profiles').select('*').eq('id',user.id).maybeSingle();
    if(error)throw error;
    return data||null;
  }catch(error){console.warn('Profile load failed',error);return null}
}
async function saveMemberPatch(patch){
  if(!authClient||!authUser)return {error:null,localOnly:true};
  try{
    const {error}=await authClient.from('profiles').update(patch).eq('id',authUser.id);
    return {error,localOnly:false};
  }catch(error){return {error,localOnly:false}}
}

let navHistory=['home'];
const motionReduced=()=>matchMedia('(prefers-reduced-motion:reduce)').matches;
const safeSessionGet=k=>{try{return sessionStorage.getItem(k)}catch{return null}};
const safeSessionSet=(k,v)=>{try{sessionStorage.setItem(k,v);return true}catch{return false}};
const safeSessionRemove=k=>{try{sessionStorage.removeItem(k)}catch{}};
const navRank={home:0,history:1,companion:2,community:3,profile:4,checkin:1,journal:1,tools:1,listen:1,read:1,privacy:4,help:4};
function setButtonLoading(button,on,label='Loading'){
  if(!button)return;
  if(on){button.dataset.label=button.textContent;button.classList.add('is-loading');button.disabled=true;button.setAttribute('aria-label',label)}
  else{button.classList.remove('is-loading');button.disabled=false;if(button.dataset.label){button.textContent=button.dataset.label;delete button.dataset.label}button.removeAttribute('aria-label')}
}
function setLaunch(open,{title='Opening Yoni',text='Preparing your private space...'}={}){
  const layer=$('#appLaunch');if(!layer)return;
  $('#appLaunchTitle').textContent=title;$('#appLaunchText').textContent=text;
  if(open){layer.hidden=false;requestAnimationFrame(()=>layer.classList.add('visible'))}
  else{layer.classList.remove('visible');setTimeout(()=>layer.hidden=true,motionReduced()?10:300)}
}
function subtleHaptic(){try{navigator.vibrate?.(8)}catch{}}
function prepareScreen(name){
  if(name==='home')renderToday();if(name==='journal')renderJournals();if(name==='history')renderCalendar();if(name==='privacy')renderPrivacy();if(name==='community')renderWall();if(name==='profile')applyProfile();
}


function toast(msg){const el=$('#toast');el.textContent=msg;el.classList.add('visible');clearTimeout(toast.t);toast.t=setTimeout(()=>el.classList.remove('visible'),2500)}
function firstName(){return String(profile.name||'friend').trim().split(/\s+/)[0]||'friend'}
function initials(){return String(profile.name||'F').trim().split(/\s+/).slice(0,2).map(x=>x[0]?.toUpperCase()).join('')||'F'}
function greeting(){const n=firstName();const hour=new Date().getHours();const morning=[`Good morning, ${n}. Dahan-dahan lang tayo today.`,`Before the day gets busy, how are you really?`,`New day. Hindi mo kailangang alam agad ang lahat.`];const afternoon=[`Quick pause, ${n}. How is your day landing so far?`,`Midday check: pahinga, space, or support?`,`You can reset the day anytime, ${n}.`];const evening=[`Good evening, ${n}. You made it through today.`,`Before you rest, what are you carrying?`,`Hindi mo kailangang ayusin lahat bago matulog.`];const anytime=[`Hey ${n}. Kamusta ka, for real?`,`Hi ${n}. No pressure. Anong kailangan mo today?`,`Welcome back. One honest feeling is enough.`,`Soft reset muna. What feels heavy today?`,`Come as you are. Walang judgment dito.`];const pool=hour<12?morning:hour<18?afternoon:evening;return [...pool,...anytime][Math.floor(Math.random()*(pool.length+anytime.length))]}
const loginPopupSessionKey='yoni-login-popups-reviewed-v1';
