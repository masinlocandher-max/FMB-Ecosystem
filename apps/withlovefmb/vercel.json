{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/js/fmb-home-approved.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/data-center",
      "has": [
        {
          "type": "host",
          "value": "www.francinemariebautista.com"
        }
      ],
      "destination": "https://data.francinemariebautista.com/",
      "permanent": true
    },
    {
      "source": "/data-center/",
      "has": [
        {
          "type": "host",
          "value": "www.francinemariebautista.com"
        }
      ],
      "destination": "https://data.francinemariebautista.com/",
      "permanent": true
    },
    {
      "source": "/data-center/index.html",
      "has": [
        {
          "type": "host",
          "value": "www.francinemariebautista.com"
        }
      ],
      "destination": "https://data.francinemariebautista.com/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "yoni.francinemariebautista.com"
        }
      ],
      "destination": "/app/",
      "permanent": false
    },
    {
