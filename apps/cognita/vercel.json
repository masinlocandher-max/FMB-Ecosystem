{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "thecognitainstitute.com" }],
      "destination": "https://www.thecognitainstitute.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?:.*\\.[^/]+))",
      "destination": "/:path"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
