# FMB Automation Hub serverless environment
# Add these as encrypted Vercel production variables. Never commit real values.

HUMAN_REVIEW_ONLY=true

# Google Apps Script receiver created from automation/google-apps-script/Code.gs
AUTOMATION_INGEST_URL=https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec
AUTOMATION_INGEST_SECRET=replace-with-a-long-random-secret
AUTOMATION_INTAKE_SECRET=replace-with-a-different-long-random-secret

# Meta webhook verification and payload authentication
META_VERIFY_TOKEN=replace-with-a-private-verification-token
META_APP_SECRET=replace-with-meta-app-secret

# Optional only when approved outbound replies are enabled later
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
